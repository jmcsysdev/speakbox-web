---
// src/pages/dispositivo.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import SubMenu from '../components/SubMenu.astro';
import EstadoWidget from '../components/EstadoWidget.jsx';
---

<BaseLayout title="Dispositivo" activePage="dispositivo">

  <SubMenu page="dispositivo" />

  <div class="page-wrap">
    <div class="container section">

      <div id="sub-pg-estado">
        <EstadoWidget client:load />
      </div>

      <div id="sub-pg-bateria" style="display:none">
        <h2 style="font-family:'DM Serif Display',Georgia,serif;font-size:28px;margin-bottom:4px">
          Batería
        </h2>
        <p style="font-size:13.5px;color:var(--tx2);margin-bottom:28px">
          Historial de carga · LiPo 3.7V / 2000mAh
        </p>
        <div class="device-grid">
          <div class="device-card">
            <div class="device-card-label">Voltaje actual</div>
            <div class="device-card-value"><span id="bat-volt">0.00</span><span style="font-size:18px"> V</span></div>
            <div class="device-card-sub">Rango saludable: 3.0V – 4.2V</div>
          </div>
          <div class="device-card">
            <div class="device-card-label">Corriente de consumo</div>
            <div class="device-card-value"><span id="bat-curr">0</span><span style="font-size:18px"> mA</span></div>
            <div class="device-card-sub">Con WiFi activo y modo Feynman</div>
          </div>
          <div class="device-card">
            <div class="device-card-label">Autonomía estimada</div>
            <div class="device-card-value" id="bat-time">--<span style="font-size:18px"></span></div>
            <div class="device-card-sub">Basado en consumo actual</div>
          </div>
          <div class="device-card">
            <div class="device-card-label">Estado de conexión</div>
            <div class="device-card-value" style="font-size:22px;color:var(--tx3)" id="bat-status">Esperando...</div>
            <div class="device-card-sub">Sincronizando con el hardware</div>
          </div>
        </div>
      </div>

      <div id="sub-pg-sensores" style="display:none">
        <h2 style="font-family:'DM Serif Display',Georgia,serif;font-size:28px;margin-bottom:4px">
          Sensores
        </h2>
        <p style="font-size:13.5px;color:var(--tx2);margin-bottom:20px">
          Todos los módulos I2C, ADC e I2S del SpeakBox
        </p>
        <div class="sensor-list">
          <div class="sensor-item">
            <div class="sensor-item-left">
              <span class="sensor-item-name">Sensor de luz digital</span>
              <span class="sensor-item-id">BH1750 · I2C 0x23 · GPIO 21/22</span>
            </div>
            <span class="sensor-item-val" id="sens-lux">-- lx</span>
          </div>
          <div class="sensor-item">
            <div class="sensor-item-left">
              <span class="sensor-item-name">Sensor de proximidad ToF</span>
              <span class="sensor-item-id">VL53L0X · I2C 0x29 · GPIO 21/22</span>
            </div>
            <span class="sensor-item-val" id="sens-dist">-- mm</span>
          </div>
          <div class="sensor-item">
            <div class="sensor-item-left">
              <span class="sensor-item-name">Monitor de corriente/voltaje</span>
              <span class="sensor-item-id">INA219 · I2C 0x40 · GPIO 21/22</span>
            </div>
            <span class="sensor-item-val" id="sens-volt">-- V</span>
          </div>
          <div class="sensor-item">
            <div class="sensor-item-left">
              <span class="sensor-item-name">LDR fotorresistencia</span>
              <span class="sensor-item-id">KY-018 · ADC1 CH3 · GPIO 4</span>
            </div>
            <span class="sensor-item-val" id="sens-ldr">-- ADC</span>
          </div>
          <div class="sensor-item">
            <div class="sensor-item-left">
              <span class="sensor-item-name">Micrófono digital I2S</span>
              <span class="sensor-item-id">INMP441 · I2S_NUM_0 · GPIO 6/7/8</span>
            </div>
            <span class="sensor-item-val" style="color:var(--gr)">OK</span>
          </div>
          <div class="sensor-item">
            <div class="sensor-item-left">
              <span class="sensor-item-name">Amplificador I2S</span>
              <span class="sensor-item-id">MAX98357A · I2S_NUM_1 · GPIO 5/7/8</span>
            </div>
            <span class="sensor-item-val" style="color:var(--gr)">OK</span>
          </div>
        </div>
      </div>

    </div>

    <footer class="footer">
      <div class="container footer-inner">
        <span class="footer-brand">SpeakBox</span>
        <span>© 2026 Laboratorio de Telecomunicaciones · UNMSM</span>
      </div>
    </footer>
  </div>

</BaseLayout>

<script>
  // ── Lógica de pestañas (ya la tenías) ──
  function showSub(sub) {
    ['estado', 'bateria', 'sensores'].forEach(s => {
      const el  = document.getElementById('sub-pg-' + s);
      const btn = document.getElementById('sub-' + s);
      if (el)  el.style.display = s === sub ? 'block' : 'none';
      if (btn) btn.classList.toggle('active', s === sub);
    });
  }

  window.addEventListener('DOMContentLoaded', () => {
    const hash = window.location.hash.replace('#', '');
    if (['estado', 'bateria', 'sensores'].includes(hash)) showSub(hash);
  });

  window.addEventListener('hashchange', () => {
    const hash = window.location.hash.replace('#', '');
    if (['estado', 'bateria', 'sensores'].includes(hash)) showSub(hash);
  });

  // ── NUEVO: Lógica de telemetría en vivo ──
  const API_BASE = "https://speakbox-backend-production.up.railway.app";

  async function actualizarSensoresYBateria() {
    try {
      const res = await fetch(`${API_BASE}/api/estado`);
      const estado = await res.json();

      if (estado && Object.keys(estado).length > 0) {
        // Variables seguras (por si alguna falta, asume 0)
        const volt = estado.voltaje || 0;
        const curr = estado.corriente || 0;
        const pct = estado.bateria_pct || 0;
        const lux = estado.lux !== undefined ? estado.lux : '--';
        const dist = estado.dist_mm !== undefined ? estado.dist_mm : '--';

        // Actualizar vista de Batería
        document.getElementById('bat-volt').textContent = volt.toFixed(2);
        document.getElementById('bat-curr').textContent = curr;
        
        // Calcular tiempo de batería estimado
        if (curr > 0) {
          const minsRestantes = Math.round((2000 * (pct / 100)) / curr * 60);
          const h = Math.floor(minsRestantes / 60);
          const m = minsRestantes % 60;
          document.getElementById('bat-time').innerHTML = `~${h}h<span style="font-size:18px"> ${m}m</span>`;
          
          const statusEl = document.getElementById('bat-status');
          statusEl.textContent = "Conectado";
          statusEl.style.color = "var(--gr)";
        }

        // Actualizar vista de Sensores
        document.getElementById('sens-lux').textContent = `${lux} lx`;
        document.getElementById('sens-dist').textContent = `${dist} mm`;
        document.getElementById('sens-volt').textContent = `${volt.toFixed(2)} V`;
        // Nota: Si envías el LDR en el futuro desde tu ESP32, se mapearía aquí.
      }
    } catch (e) {
      console.log("Esperando telemetría del ESP32...");
    }
  }

  // Ejecutar inmediatamente y luego cada 5 segundos
  actualizarSensoresYBateria();
  setInterval(actualizarSensoresYBateria, 5000);
</script>