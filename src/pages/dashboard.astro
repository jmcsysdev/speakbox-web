---
// src/pages/dashboard.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---
 
<BaseLayout title="Dashboard" activePage="dashboard">
 
  <div class="page-wrap no-sub">
 
    <div class="dash-hero">
      <div class="container">
        <div class="dash-hero-inner">
          <div>
            <p style="font-size:12px;color:var(--tx3);font-family:'JetBrains Mono',monospace;letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px" id="fecha-actual"></p>
            <h1>Buenos días, <em style="font-style:italic;color:var(--gr)" id="saludo-nombre">estudiante</em></h1>
            <p style="margin-top:8px;font-size:13.5px;color:var(--tx2)" id="resumen-texto">
              Aún no tienes sesiones registradas.
            </p>
            <div class="device-pill" id="estado-conexion">Cargando conexión...</div>
          </div>
          <div style="display:flex;gap:10px;align-items:flex-start;flex-wrap:wrap">
            <a href="/dispositivo" class="btn btn-primary" style="font-size:13px;text-decoration:none">Ver sesión actual</a>
            <a href="/sesiones" class="btn btn-ghost" style="font-size:13px;text-decoration:none">Ver historial</a>
          </div>
        </div>
      </div>
    </div>
 
    <div class="container">
 
      <div class="mode-cards">
        <a href="/sesiones?modo=feynman" class="mode-card" style="text-decoration:none;color:inherit">
          <div class="mode-card-icon">🧠</div>
          <h3>Feynman</h3>
          <p>Evalúa tu comprensión con preguntas socráticas.</p>
          <div class="stat-row">
            <span class="stat-pill" id="stat-feynman">0 sesiones</span>
            <span class="stat-pill">Nivel: --</span>
          </div>
        </a>
        <a href="/sesiones?modo=pomodoro" class="mode-card" style="text-decoration:none;color:inherit">
          <div class="mode-card-icon">🍅</div>
          <h3>Pomodoro</h3>
          <p>Bloques de 25 min de enfoque + 5 de descanso.</p>
          <div class="stat-row">
            <span class="stat-pill" id="stat-pomodoro">0 bloques</span>
            <span class="stat-pill" id="stat-pomodoro-time">0 min</span>
          </div>
        </a>
        <a href="/sesiones?modo=respiracion" class="mode-card" style="text-decoration:none;color:inherit">
          <div class="mode-card-icon">🌬️</div>
          <h3>Respiración</h3>
          <p>Técnica 4-7-8 para reducir ansiedad antes de estudiar.</p>
          <div class="stat-row">
            <span class="stat-pill" id="stat-respiracion">0 sesiones</span>
            <span class="stat-pill">Última: --</span>
          </div>
        </a>
      </div>
 
      <div class="chart-section">
        <h2>Bloques Pomodoro esta semana</h2>
        <p class="sub">Cada barra = bloques de 25 min completados</p>
        <div class="bar-chart" id="bar-chart-pomodoro"></div>
      </div>
 
      <div class="recientes">
        <h2>Sesiones recientes</h2>
        <div class="mini-tabla" id="tabla-recientes"></div>
        <div style="margin-top:14px">
          <a href="/sesiones" class="btn btn-ghost btn-sm" style="text-decoration:none">Ver todas las sesiones →</a>
        </div>
      </div>
    </div>
 
    <footer class="footer">
      <div class="container footer-inner">
        <span class="footer-brand">SpeakBox</span>
        <span>© 2026 Laboratorio de Telecomunicaciones · UNMSM</span>
      </div>
    </footer>
  </div>
 
  <div class="modal-overlay" id="modal-dash" onclick="if(event.target===this)cerrarModal()">
    <div class="modal">
      <div class="modal-head">
        <div>
          <h3 id="modal-titulo"></h3>
          <p style="font-size:12px;color:var(--tx3);margin-top:4px" id="modal-meta"></p>
        </div>
        <button class="modal-close" onclick="cerrarModal()">×</button>
      </div>
      <div class="modal-body">
        <div class="modal-field">
          <label>Lo que explicaste</label>
          <div class="transcript-box" id="modal-transcript"></div>
        </div>
        <div class="modal-field">
          <label>Respuesta del SpeakBox</label>
          <p id="modal-resp"></p>
        </div>
      </div>
    </div>
  </div>
 
</BaseLayout>
 
<script>
  const API_BASE = "https://speakbox-backend-production.up.railway.app";
 
  // Si no inició sesión, redirigir al login
  const sbUserId   = sessionStorage.getItem('sb_user_id');
  const sbUsername = sessionStorage.getItem('sb_username');
  if (!sbUserId) {
    window.location.href = '/cuenta';
  } else {
    document.getElementById('saludo-nombre').textContent = sbUsername;
  }
 
  async function cargarDatos() {
    try {
      const res = await fetch(`${API_BASE}/api/sesiones?user_id=${sbUserId}`);
      const data = await res.json();
      const sesiones = data.sesiones || [];
 
      // 1. Actualizar Tarjetas (Feynman, Pomodoro, Respiración)
      const fey = sesiones.filter(s => s.modo === 'feynman');
      const pom = sesiones.filter(s => s.modo === 'pomodoro');
      const respi = sesiones.filter(s => s.modo === 'respiracion');
      
      document.getElementById('stat-feynman').textContent = `${fey.length} sesiones`;
      document.getElementById('stat-pomodoro').textContent = `${pom.length} bloques`;
      document.getElementById('stat-respiracion').textContent = `${respi.length} sesiones`;
      
      if (sesiones.length > 0) {
        document.getElementById('resumen-texto').textContent = `Esta semana llevas ${fey.length} sesiones Feynman y ${pom.length} bloques Pomodoro.`;
      }
 
      // Calcular tiempo total Pomodoro
      const totalSeg = pom.reduce((acc, s) => acc + (s.duracion_seg || 0), 0);
      const mins = Math.floor(totalSeg / 60);
      document.getElementById('stat-pomodoro-time').textContent = `${mins} min`;
 
      // 2. Renderizar Tabla
      const tabla = document.getElementById('tabla-recientes');
      if (sesiones.length > 0) {
        tabla.innerHTML = `
          <div class="mini-tabla-head"><span>Tema</span><span>Duración</span><span>Fecha</span></div>
          ${sesiones.slice(0, 3).map(s => `
            <div class="mini-tabla-row" style="cursor:pointer" onclick="window.abrirModal(${JSON.stringify(s).replace(/"/g, '&quot;')})">
              <span class="tema">${s.modo || 'Sesión'}</span>
              <span class="dur">${s.duracion_seg} seg</span>
              <span class="fecha">${s.fecha.substring(0, 10)}</span>
            </div>
          `).join('')}
        `;
      } else {
        tabla.innerHTML = '<div style="padding: 20px; text-align: center; color: var(--tx3); font-size: 13px;">No hay sesiones recientes.</div>';
      }
 
      // 3. Renderizar Gráfico
      const cont = document.getElementById('bar-chart-pomodoro');
      cont.innerHTML = `
        <div class="bar-col">
          <div class="bar" style="height: ${pom.length > 0 ? '80px' : '0px'}"><span class="bar-val">${pom.length}</span></div>
          <span class="bar-lbl">Total</span>
        </div>
      `;
 
      // 4. Estado conexión
      const resEst = await fetch(`${API_BASE}/api/estado`);
      const est = await resEst.json();
      if (est && Object.keys(est).length > 0) {
        document.getElementById('estado-conexion').textContent = `SpeakBox conectado · Batería ${est.bateria_pct}%`;
      } else {
        document.getElementById('estado-conexion').textContent = `Esperando conexión...`;
      }
 
    } catch (e) { console.error("Error cargando dashboard:", e); }
  }
 
  window.abrirModal = (s) => {
    document.getElementById('modal-titulo').textContent = s.modo;
    document.getElementById('modal-meta').textContent = s.fecha;
    document.getElementById('modal-transcript').textContent = s.transcripcion;
    document.getElementById('modal-resp').textContent = s.respuesta_ia;
    document.getElementById('modal-dash').classList.add('open');
  };
 
  window.cerrarModal = () => document.getElementById('modal-dash').classList.remove('open');
 
  document.getElementById('fecha-actual').textContent = new Date().toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'short', day: 'numeric' });
  cargarDatos();
</script>
