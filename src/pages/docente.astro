---
// src/pages/docente.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Vista Docente" activePage="docente">

  <div class="page-wrap no-sub">
    <div class="container section">

      <!-- Título -->
      <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:4px">
        <h2 style="font-family:'DM Serif Display',Georgia,serif;font-size:28px">
          Vista del Docente
        </h2>
        <span style="font-size:12px;font-family:'JetBrains Mono',monospace;color:var(--tx3)">
          TCI V Ciclo · Sección A
        </span>
      </div>
      <p style="font-size:13.5px;color:var(--tx2);margin-bottom:28px">
        Monitoreo en tiempo real de los dispositivos SpeakBox de tus alumnos.
      </p>

      <!-- Alerta batería baja -->
      <div class="alert alert-warn">
        <span class="alert-icon">⚠️</span>
        <div>
          <strong>2 alumnos con batería baja</strong> — García (12%) y Quispe (8%).
          Sus dispositivos se apagarán pronto.
        </div>
      </div>

      <!-- Stats globales -->
      <div class="docente-grid">
        <div class="stat-card">
          <div class="stat-card-label">Alumnos activos hoy</div>
          <div class="stat-card-num">14</div>
          <div class="stat-card-sub">de 20 inscritos</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Sesiones Feynman totales</div>
          <div class="stat-card-num">87</div>
          <div class="stat-card-sub">Esta semana · Nivel prom. 6.8/10</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-label">Bloques Pomodoro</div>
          <div class="stat-card-num">312</div>
          <div class="stat-card-sub">Esta semana · 130 horas de enfoque</div>
        </div>
      </div>

      <!-- Tabla de alumnos -->
      <h3 style="font-size:17px;font-weight:600;margin-bottom:16px">Dispositivos activos</h3>
      <div class="alumnos-lista">
        <div class="alumnos-head">
          <span>Alumno</span>
          <span>Batería</span>
          <span>Modo</span>
          <span>Sesiones</span>
          <span>Últ. actividad</span>
        </div>
        <div class="alumno-row">
          <div>
            <div class="alumno-name">López Ramírez, A.</div>
            <div class="alumno-id">speakbox-04</div>
          </div>
          <span class="bat-ok">78%</span>
          <span><span class="nivel-badge nivel-alto" style="font-size:10px">Feynman</span></span>
          <span style="font-size:13px">12</span>
          <span style="font-size:12px;color:var(--tx3)">Hace 2 min</span>
        </div>
        <div class="alumno-row">
          <div>
            <div class="alumno-name">García Torres, M.</div>
            <div class="alumno-id">speakbox-07</div>
          </div>
          <span class="bat-warn">12% ⚠️</span>
          <span><span class="nivel-badge" style="background:#F0EDF7;color:#5C3D9B;font-size:10px">Pomodoro</span></span>
          <span style="font-size:13px">8</span>
          <span style="font-size:12px;color:var(--tx3)">Ahora</span>
        </div>
        <div class="alumno-row">
          <div>
            <div class="alumno-name">Quispe Mamani, R.</div>
            <div class="alumno-id">speakbox-11</div>
          </div>
          <span class="bat-warn">8% ⚠️</span>
          <span><span class="nivel-badge nivel-alto" style="font-size:10px">Feynman</span></span>
          <span style="font-size:13px">15</span>
          <span style="font-size:12px;color:var(--tx3)">Hace 5 min</span>
        </div>
        <div class="alumno-row">
          <div>
            <div class="alumno-name">Vargas Ccoa, F.</div>
            <div class="alumno-id">speakbox-02</div>
          </div>
          <span class="bat-ok">94%</span>
          <span><span class="nivel-badge" style="background:#E8F4F8;color:#2A6B8A;font-size:10px">Respiración</span></span>
          <span style="font-size:13px">5</span>
          <span style="font-size:12px;color:var(--tx3)">Hace 12 min</span>
        </div>
      </div>

    </div><!-- /container -->

    <footer class="footer">
      <div class="container footer-inner">
        <span class="footer-brand">SpeakBox</span>
        <span>© 2026 Laboratorio de Telecomunicaciones · UNMSM</span>
      </div>
    </footer>
  </div>

</BaseLayout>
